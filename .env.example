# Canonical site URL — must include http:// or https:// (e.g. http://localhost:3000 for local dev).
# Values like "localhost:3000" alone will break the app; this file shows the correct form.
NEXT_PUBLIC_SITE_URL=https://automind-ventures.vercel.app

# Business WhatsApp number (country code, no +)
NEXT_PUBLIC_WHATSAPP_NUMBER=2348055906616

# Optional: Vercel Blob — public HTTPS URLs for receipts so WhatsApp messages can include a link (link preview).
# Create a store in the Vercel dashboard and pull env, or set manually for local dev.
# BLOB_READ_WRITE_TOKEN=
