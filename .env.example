# Canonical site URL (used for Open Graph and WhatsApp receipt links)
NEXT_PUBLIC_SITE_URL=https://automind-ventures.vercel.app

# Business WhatsApp number (country code, no +)
NEXT_PUBLIC_WHATSAPP_NUMBER=2348055906616

# MongoDB connection string (Atlas recommended)
MONGODB_URI=

# Vercel Blob — required for receipt uploads in production on Vercel.
# Create Blob storage in the Vercel dashboard and connect it to this project.
# For local dev, uploads use public/uploads/ and this can be omitted.
BLOB_READ_WRITE_TOKEN=
