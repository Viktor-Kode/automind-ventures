PORT=5000
NODE_ENV=development

# MongoDB (Atlas or local)
MONGODB_URI=mongodb://127.0.0.1:27017/taskmanager

JWT_SECRET=change_me_to_a_long_random_string

# Frontend URL (no trailing slash) — used for CORS and Flutterwave redirect after payment
FRONTEND_URL=http://localhost:3000

# Flutterwave (https://dashboard.flutterwave.com — Settings → API)
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
# Webhook secret hash from Flutterwave dashboard (Settings → Webhooks)
FLUTTERWAVE_SECRET_HASH=

# Optional
APP_NAME=Automind
